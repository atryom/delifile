{
  "name": "delifile",
  "version": "0.5.82",
  "description": "FileSpace MVP — Angular 21 SPA",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build && node scripts/postbuild.js",
    "build:prod": "ng build --configuration production && node scripts/postbuild.js",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@tiptap/core": "^3.23.5",
    "@tiptap/extension-code-block": "^3.23.5",
    "@tiptap/extension-image": "^3.23.5",
    "@tiptap/extension-link": "^3.23.5",
    "@tiptap/extension-table": "^3.23.5",
    "@tiptap/extension-table-cell": "^3.23.5",
    "@tiptap/extension-table-header": "^3.23.5",
    "@tiptap/extension-table-row": "^3.23.5",
    "@tiptap/extension-task-item": "^3.23.5",
    "@tiptap/extension-task-list": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "rxjs": "~7.8.0",
    "tiptap-markdown": "^0.9.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.1",
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.0",
    "unzip": "^0.1.11",
    "vitest": "^4.0.8"
  }
